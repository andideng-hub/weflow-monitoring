# N8N API (HG Insights Operations instance)
N8N_API_KEY=your-n8n-api-key
N8N_BASE_URL=https://hginsightsoperations.app.n8n.cloud/api/v1

# Google Workspace credentials file path
# OAuth JSON with client_id, client_secret, refresh_token
# Used by the "Refresh Google Token" node in the workflow
GOOGLE_CREDS_PATH=~/.google_workspace_mcp/credentials/your-email@hginsights.com.json
